{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "build": {
    "env": {
      "LIGHTNINGCSS_FORCE_WASM": "1"
    }
  },
  "env": {
    "LIGHTNINGCSS_FORCE_WASM": "1"
  },
  "crons": [
    {
      "path": "/api/capital-os/sync/cron",
      "schedule": "0 19 * * *"
    }
  ]
}