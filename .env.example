# =============================================================================
# Nexus monorepo — environment template
# Copy to .env.local for local dev. Vercel reads its own env per environment.
# =============================================================================

# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Tag Manager ID
NEXT_PUBLIC_GTM_MEASUREMENT_ID=GTM-XXXXXXX

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=https://thanachon.me

# ---------- ChatBase ----------
# ChatBase widget embed script ID
NEXT_PUBLIC_CHATBASE_EMBED_ID=your-chatbase-embed-id

# GitHub Personal Access Token for fetching contribution stats
# Required scopes: read:user, public_repo
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token

# Optional: Resend API key (only if using Netlify Function for custom email formatting)
RESEND_API_KEY=re_your_resend_api_key

# ---------- Prisma (the Postgres connection) ----------
# `DATABASE_URL` is the *pooled* connection string (PgBouncer port 6543) used at
# runtime by the Prisma client. Append `?pgbouncer=true&connection_limit=1` so
# transaction-mode pooling works.
DATABASE_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# `DIRECT_URL` is the *direct* connection (port 5432). Only used by `prisma migrate`
# and `prisma db pull`/`db push` — never at runtime. Required because PgBouncer
# breaks long-running migration statements.
DIRECT_URL="postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ---------- Supabase (shared by Praxis + MarketOS) ----------
# Project: your-project-id
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# "Publishable" / anon JWT — safe to expose to the browser. Used by SSR + browser clients.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Service-role JWT — NEVER expose. Used by server-only admin routes (invite, callback, etc.).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---------- MarketOS ----------
# Slug of the org served to anonymous public visitors on /prototypes/market-os/*.
# Must match the slug created by `npm run db:seed`.
NEXT_PUBLIC_MARKETOS_DEMO_ORG_SLUG=nexus

# ---------- Praxis ----------
# Short-lived invite JWT signing secret.
# Generate with `npm run praxis:secret` (cross-platform) or, on Unix, `openssl rand -base64 32`.
PRAXIS_INVITE_SECRET=replace-me-with-32-char-base64
# Shared secret required by POST /api/praxis/invite via the `x-praxis-admin-token`
# header. Also generated with `npm run praxis:secret`.
# See specs/010-praxis-learning-platform/contracts/auth.invite.md.
PRAXIS_ADMIN_TOKEN=replace-me-with-32-char-base64
# UUID of an auth.users row that owns `praxis_invitations.invited_by`.
# Seed via Supabase Studio > Authentication > Add user, then paste the id here.
# PRAXIS_INVITER_USER_ID=00000000-0000-0000-0000-000000000000

# Resend sender identity (must be a verified domain/address in Resend).
# Defaults used if unset: sender "PRAXIS · Thanachon Supasatian <praxis@thanachon.me>".
PRAXIS_EMAIL_FROM=noreply-praxis@thanachon.me
PRAXIS_EMAIL_FROM_NAME="PRAXIS · Thanachon Supasatian"

# Universal model for all generation tasks (default: google/gemini-3-flash-preview)
PRAXIS_LLM_MODEL=google/gemini-3-flash-preview

# Task-specific overrides (optional — fall back to PRAXIS_LLM_MODEL if unset)
PRAXIS_LLM_GUARDDRAIL_MODEL=google/gemini-3-flash-preview
PRAXIS_LLM_CURRICULUM_MODEL=google/gemini-3-flash-preview
PRAXIS_LLM_UNIT_MODEL=google/gemini-3-flash-preview
PRAXIS_LLM_ONBOARDING_MODEL=google/gemini-3-flash-preview
PRAXIS_LLM_JUDGE_MODEL=google/gemini-3-flash-preview

# Optional monthly spend ceiling (cents)
# PRAXIS_MONTHLY_BUDGET_CENTS=5000

# ---------- OpenRouter ----------
# Sign up at https://openrouter.ai, then create a key under "Keys".
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key

# ---- LLM Model Configuration (Centralized) ----
# Set one universal model, or use task-specific overrides.
# All models must be valid OpenRouter slugs (see https://openrouter.ai/models).

# YNAB Access Token for financial data
YNAB_ACCESS_TOKEN=your-ynab-access-token

CURRENCY_FREAKS_TOKEN=your-currency-freaks-token