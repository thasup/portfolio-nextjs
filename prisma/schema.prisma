model CapitalPositionSnapshot {
  id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  snapshotId       String                  @map("snapshot_id") @db.Uuid
  ticker           String
  portfolioName    String                  @map("portfolio_name")
  sharesHeld       Float                   @map("shares_held")
