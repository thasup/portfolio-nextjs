  snapshotDate       DateTime                  @map("snapshot_date")
  importMethod       String                    @map("import_method")
  totalValueUsd      BigInt                    @map("total_value_usd")
  totalValueThb      BigInt                    @map("total_value_thb")
  fxRateUsdThb       Float                     @map("fx_rate_usd_thb")
  totalProfitUsd     BigInt                    @map("total_profit_usd")
  totalProfitPct     Float                     @map("total_profit_pct")
  irrPct             Float                     @map("irr_pct")
  passiveIncomeUsd   BigInt                    @map("passive_income_usd")
  passiveYieldPct    Float                     @map("passive_yield_pct")
  cashBalanceUsd     BigInt?                   @map("cash_balance_usd")
  strategicValueUsd  BigInt?                   @map("strategic_value_usd")
  strategicAllocPct  Float?                    @map("strategic_alloc_pct")
  strategicProfitPct Float?                    @map("strategic_profit_pct")
  tacticalValueUsd   BigInt?                   @map("tactical_value_usd")
  tacticalAllocPct   Float?                    @map("tactical_alloc_pct")
  tacticalProfitPct  Float?                    @map("tactical_profit_pct")
  globalEquitiesUsd  BigInt?                   @map("global_equities_usd")
  globalEquitiesPct  Float?                    @map("global_equities_pct")
  fixedIncomeUsd     BigInt?                   @map("fixed_income_usd")
  fixedIncomePct     Float?                    @map("fixed_income_pct")
  realAssetUsd       BigInt?                   @map("real_asset_usd")
  thematicUsd        BigInt?                   @map("thematic_usd")
  airtableSnapshotId String?                   @map("airtable_snapshot_id")
  notes              String?
