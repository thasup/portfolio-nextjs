generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  /// FK to auth.users(id), enforced at SQL level.
  id                       String                    @id @db.Uuid
  email                    String                    @unique(map: "praxis_learners_email_key")
  displayName              String?                   @map("display_name")
  /// 'en' | 'th' (check constraint in SQL).
  defaultLocale            String                    @default("en") @map("default_locale")
  canGenerateTopics        Boolean                   @default(false) @map("can_generate_topics")
  /// JSONB object: { guardrail?, curriculum?, unit?, onboarding?, judge? }
  modelPreferences         Json?                     @map("model_preferences")
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastActiveAt             DateTime                  @default(now()) @map("last_active_at") @db.Timestamptz(6)
  role                     Role?                     @default(MEMBER)
  canSeePrototypes         Boolean                   @default(false) @map("can_see_prototypes")
  capitalAccounts          CapitalAccount[]
  capitalAirtableConfigs   CapitalAirtableConfig[]
  capitalAirtableSnapshots CapitalAirtableSnapshot[]
  capitalAlerts            CapitalAlert[]
  capitalGoals             CapitalGoal[]
  capitalLiabilities       CapitalLiability[]
  capitalMappingConfigs    CapitalMappingConfig[]    @relation("UserMappingConfigs")
  capitalSACategories      CapitalSACategory[]       @relation("UserSACategories")
  capitalScenarios         CapitalScenario[]
  capitalSettings          CapitalSettings?
  capitalSnapshots         CapitalSnapshot[]
  capitalSnowballSnapshots CapitalSnowballSnapshot[]
  capitalSyncLogs          CapitalSyncLog[]
  marketosMembers          MarketosMember[]
  orgsCreated              MarketosOrg[]             @relation("OrgCreator")
  conversations            PraxisConversation[]
  invitations              PraxisInvitation[]        @relation("Inviter")
  onboarding               PraxisOnboarding[]
  templates                PraxisTemplate[]
  topics                   PraxisTopic[]

  @@map("nexus_users")
}

model PraxisInvitation {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String    @unique
  /// FK to auth.users(id) (the inviter).
  invitedBy String    @map("invited_by") @db.Uuid
  invitedAt DateTime  @default(now()) @map("invited_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  note      String?
  inviter   User      @relation("Inviter", fields: [invitedBy], references: [id])

  @@map("praxis_invitations")
}

model PraxisCurriculumCache {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fingerprint  String
  locale       String   @default("en")
  units        Json
  modelVersion String   @map("model_version")
  hitCount     Int      @default(0) @map("hit_count")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([fingerprint, locale, modelVersion])
  @@map("praxis_curriculum_cache")
}

model PraxisUnitCache {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fingerprint  String
  locale       String   @default("en")
  unitIndex    Int      @map("unit_index")
  blocks       Json
  modelVersion String   @map("model_version")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([fingerprint, locale, unitIndex, modelVersion])
  @@map("praxis_unit_cache")
}

model PraxisTopic {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String               @map("user_id") @db.Uuid
  title         String
  rawInput      String               @map("raw_input")
  fingerprint   String
  locale        String               @default("en")
  /// pending_guardrail | rejected | outline_ready | active | archived
  status        String               @default("pending_guardrail")
  curriculumId  String?              @map("curriculum_id") @db.Uuid
  lastActiveAt  DateTime             @default(now()) @map("last_active_at") @db.Timestamptz(6)
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  conversations PraxisConversation[]
  onboarding    PraxisOnboarding[]
  templates     PraxisTemplate[]
  user          User                 @relation(fields: [userId], references: [id])
  units         PraxisUnit[]

  @@index([fingerprint, locale], map: "praxis_topics_fingerprint_idx")
  @@index([userId, lastActiveAt(sort: Desc)], map: "praxis_topics_learner_active_idx")
  @@map("praxis_topics")
}

model PraxisUnit {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topicId       String               @map("topic_id") @db.Uuid
  index         Int
  title         String
  objective     String
  /// pending | ready | completed
  status        String               @default("pending")
  blocks        Json                 @default("[]")
  cacheId       String?              @map("cache_id") @db.Uuid
  completedAt   DateTime?            @map("completed_at") @db.Timestamptz(6)
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  conversations PraxisConversation[]
  templates     PraxisTemplate[]
  topic         PraxisTopic          @relation(fields: [topicId], references: [id])

  @@unique([topicId, index])
  @@map("praxis_units")
}

model PraxisConversation {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String          @map("user_id") @db.Uuid
  topicId       String          @map("topic_id") @db.Uuid
  unitId        String?         @map("unit_id") @db.Uuid
  /// unit | mate (check + invariant: unit_id non-null iff surface = 'unit')
  surface       String
  summary       String?
  lastMessageAt DateTime?       @map("last_message_at") @db.Timestamptz(6)
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  topic         PraxisTopic     @relation(fields: [topicId], references: [id])
  unit          PraxisUnit?     @relation(fields: [unitId], references: [id])
  user          User            @relation(fields: [userId], references: [id])
  messages      PraxisMessage[]

  @@index([userId, lastMessageAt(sort: Desc)], map: "praxis_conversations_learner_recent_idx")
  @@index([topicId], map: "praxis_conversations_topic_idx")
  @@map("praxis_conversations")
}

model PraxisMessage {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId   String             @map("conversation_id") @db.Uuid
  /// user | assistant
  role             String
  content          String
  tokenCountInput  Int?               @map("token_count_input")
  tokenCountOutput Int?               @map("token_count_output")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  conversation     PraxisConversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt], map: "praxis_messages_conversation_idx")
  @@map("praxis_messages")
}

model PraxisOnboarding {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  topicId   String      @map("topic_id") @db.Uuid
  version   Int         @default(1)
  answers   Json
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  topic     PraxisTopic @relation(fields: [topicId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@unique([userId, topicId, version], map: "praxis_onboarding_learner_id_topic_id_version_key")
  @@map("praxis_onboarding")
}

model PraxisTemplate {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String      @map("user_id") @db.Uuid
  topicId        String      @map("topic_id") @db.Uuid
  unitId         String?     @map("unit_id") @db.Uuid
  /// docx | xlsx | pdf
  kind           String
  title          String
  specJson       Json        @map("spec_json")
  regenerateNote String?     @map("regenerate_note")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  topic          PraxisTopic @relation(fields: [topicId], references: [id])
  unit           PraxisUnit? @relation(fields: [unitId], references: [id])
  user           User        @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)], map: "praxis_templates_learner_idx")
  @@map("praxis_templates")
}

model PraxisSpendLedger {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp      DateTime @default(now()) @db.Timestamptz(6)
  /// chat | curriculum | unit | onboarding | template | guardrail
  endpoint       String
  inputTokens    Int      @map("input_tokens")
  outputTokens   Int      @map("output_tokens")
  estimatedCents Int      @map("estimated_cents")
  model          String

  @@index([timestamp(sort: Desc)])
  @@map("praxis_spend_ledger")
}

model MarketosOrg {
  id             String                  @id @default(uuid()) @db.Uuid
  slug           String                  @unique
  name           String
  /// ISO-4217. MVP-locked to 'USD'; checked at SQL level.
  currency       String                  @default("USD")
  /// FK to auth.users(id) (the org creator). Nullable for the seed.
  createdBy      String?                 @map("created_by") @db.Uuid
  archivedAt     DateTime?               @map("archived_at") @db.Timestamptz(6)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  invitations    MarketosInvitation[]
  members        MarketosMember[]
  missions       MarketosMission[]
  notifications  MarketosNotification[]
  settings       MarketosOrgSettings?
  creator        User?                   @relation("OrgCreator", fields: [createdBy], references: [id])
  payouts        MarketosPayout[]
  revenuePeriods MarketosRevenuePeriod[]

  @@map("marketos_orgs")
}

model MarketosMember {
  id              String                 @id @default(uuid()) @db.Uuid
  orgId           String                 @map("org_id") @db.Uuid
  /// FK to auth.users(id).
  userId          String                 @map("user_id") @db.Uuid
  /// owner | admin | member (check at SQL level).
  role            String
  displayName     String                 @map("display_name")
  title           String?
  bio             String?
  skills          String[]               @default([])
  baseCompCents   BigInt                 @default(0) @map("base_comp_cents")
  joinedAt        DateTime               @default(now()) @map("joined_at") @db.Timestamptz(6)
  removedAt       DateTime?              @map("removed_at") @db.Timestamptz(6)
  bids            MarketosBid[]
  decidedBids     MarketosBid[]          @relation("BidDecider")
  org             MarketosOrg            @relation(fields: [orgId], references: [id])
  user            User                   @relation(fields: [userId], references: [id])
  postedMissions  MarketosMission[]      @relation("MissionPoster")
  notifications   MarketosNotification[]
  payouts         MarketosPayout[]       @relation("PayoutRecipient")
  reviewsReceived MarketosReview[]       @relation("ReviewReviewee")
  reviewsGiven    MarketosReview[]       @relation("ReviewReviewer")

  @@unique([orgId, userId])
  @@index([orgId, removedAt], map: "marketos_members_org_active_idx")
  @@map("marketos_members")
}

model MarketosInvitation {
  id         String      @id @default(uuid()) @db.Uuid
  orgId      String      @map("org_id") @db.Uuid
  email      String
  /// FK to auth.users(id) (the inviter).
  invitedBy  String      @map("invited_by") @db.Uuid
  /// admin | member (check at SQL level).
  role       String
  invitedAt  DateTime    @default(now()) @map("invited_at") @db.Timestamptz(6)
  acceptedAt DateTime?   @map("accepted_at") @db.Timestamptz(6)
  revokedAt  DateTime?   @map("revoked_at") @db.Timestamptz(6)
  note       String?
  org        MarketosOrg @relation(fields: [orgId], references: [id])

  @@unique([orgId, email])
  @@map("marketos_invitations")
}

model MarketosOrgSettings {
  orgId           String      @id @map("org_id") @db.Uuid
  /// 0–100; check constraint.
  payrollRatioPct Int         @map("payroll_ratio_pct")
  /// 0–100; check constraint.
  baseSplitPct    Int         @map("base_split_pct")
  /// month | quarter | half (check).
  period          String
  /// orange | blue | green (check). Cosmetic.
  accent          String      @default("orange")
  darkMode        Boolean     @default(false) @map("dark_mode")
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  /// FK to auth.users(id).
  updatedBy       String?     @map("updated_by") @db.Uuid
  org             MarketosOrg @relation(fields: [orgId], references: [id])

  @@map("marketos_org_settings")
}

model MarketosRevenuePeriod {
  id              String           @id @default(uuid()) @db.Uuid
  orgId           String           @map("org_id") @db.Uuid
  /// month | quarter | half — denormalised to preserve historical accuracy.
  period          String
  /// Human label like "Q3 2025" — used directly in UI.
  periodLabel     String           @map("period_label")
  periodStart     DateTime         @map("period_start") @db.Date
  periodEnd       DateTime         @map("period_end") @db.Date
  revenueCents    BigInt           @map("revenue_cents")
  /// Snapshot of org settings at close time.
  payrollRatioPct Int              @map("payroll_ratio_pct")
  /// Snapshot of org settings at close time.
  baseSplitPct    Int              @map("base_split_pct")
  /// Exactly one row per org has this true (partial unique index in SQL).
  isCurrent       Boolean          @default(false) @map("is_current")
  closedAt        DateTime?        @map("closed_at") @db.Timestamptz(6)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  payouts         MarketosPayout[]
  org             MarketosOrg      @relation(fields: [orgId], references: [id])

  @@unique([orgId, periodLabel])
  @@index([orgId, periodStart(sort: Desc)], map: "marketos_revenue_periods_history_idx")
  @@map("marketos_revenue_periods")
}

model MarketosMission {
  id            String           @id @default(uuid()) @db.Uuid
  orgId         String           @map("org_id") @db.Uuid
  posterId      String           @map("poster_id") @db.Uuid
  title         String
  slug          String
  description   String
  /// Design | Engineering | Research | Marketing | HR | Operations (check).
  category      String
  /// Array of strings, length 1–10.
  deliverables  Json
  budgetCents   BigInt           @map("budget_cents")
  deadline      DateTime         @db.Date
  /// open | active | delivered | completed | cancelled (check).
  status        String           @default("open")
  /// Set when a bid is accepted. Nullable while open.
  acceptedBidId String?          @unique @map("accepted_bid_id") @db.Uuid
  deliveredAt   DateTime?        @map("delivered_at") @db.Timestamptz(6)
  completedAt   DateTime?        @map("completed_at") @db.Timestamptz(6)
  cancelledAt   DateTime?        @map("cancelled_at") @db.Timestamptz(6)
  archivedAt    DateTime?        @map("archived_at") @db.Timestamptz(6)
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  bids          MarketosBid[]
  acceptedBid   MarketosBid?     @relation("AcceptedBid", fields: [acceptedBidId], references: [id])
  org           MarketosOrg      @relation(fields: [orgId], references: [id])
  poster        MarketosMember   @relation("MissionPoster", fields: [posterId], references: [id])
  payouts       MarketosPayout[]
  reviews       MarketosReview[]

  @@unique([orgId, slug])
  @@index([orgId, status, createdAt(sort: Desc)], map: "marketos_missions_board_idx")
  @@index([posterId], map: "marketos_missions_poster_idx")
  @@map("marketos_missions")
}

model MarketosBid {
  id          String           @id @default(uuid()) @db.Uuid
  missionId   String           @map("mission_id") @db.Uuid
  bidderId    String           @map("bidder_id") @db.Uuid
  amountCents BigInt           @map("amount_cents")
  proposal    String
  /// pending | shortlisted | accepted | declined | withdrawn (check).
  status      String           @default("pending")
  submittedAt DateTime         @default(now()) @map("submitted_at") @db.Timestamptz(6)
  decidedAt   DateTime?        @map("decided_at") @db.Timestamptz(6)
  decidedBy   String?          @map("decided_by") @db.Uuid
  bidder      MarketosMember   @relation(fields: [bidderId], references: [id])
  decider     MarketosMember?  @relation("BidDecider", fields: [decidedBy], references: [id])
  mission     MarketosMission  @relation(fields: [missionId], references: [id])
  acceptedFor MarketosMission? @relation("AcceptedBid")
  payout      MarketosPayout?

  @@unique([missionId, bidderId])
  @@index([bidderId, submittedAt(sort: Desc)], map: "marketos_bids_my_idx")
  @@map("marketos_bids")
}

model MarketosPayout {
  id                String                @id @default(uuid()) @db.Uuid
  /// 1:1 with the accepted bid.
  bidId             String                @unique @map("bid_id") @db.Uuid
  /// Denormalised for fast queries.
  missionId         String                @map("mission_id") @db.Uuid
  /// Denormalised.
  orgId             String                @map("org_id") @db.Uuid
  recipientMemberId String                @map("recipient_member_id") @db.Uuid
  amountCents       BigInt                @map("amount_cents")
  /// The period this payout debits.
  revenuePeriodId   String                @map("revenue_period_id") @db.Uuid
  scheduledFor      DateTime              @map("scheduled_for") @db.Date
  /// scheduled | released | voided (check).
  status            String                @default("scheduled")
  releasedAt        DateTime?             @map("released_at") @db.Timestamptz(6)
  voidedAt          DateTime?             @map("voided_at") @db.Timestamptz(6)
  bid               MarketosBid           @relation(fields: [bidId], references: [id])
  mission           MarketosMission       @relation(fields: [missionId], references: [id])
  org               MarketosOrg           @relation(fields: [orgId], references: [id])
  recipient         MarketosMember        @relation("PayoutRecipient", fields: [recipientMemberId], references: [id])
  revenuePeriod     MarketosRevenuePeriod @relation(fields: [revenuePeriodId], references: [id])

  @@index([orgId, scheduledFor], map: "marketos_payouts_org_due_idx")
  @@index([recipientMemberId, status], map: "marketos_payouts_recipient_status_idx")
  @@map("marketos_payouts")
}

model MarketosReview {
  id         String          @id @default(uuid()) @db.Uuid
  missionId  String          @map("mission_id") @db.Uuid
  reviewerId String          @map("reviewer_id") @db.Uuid
  revieweeId String          @map("reviewee_id") @db.Uuid
  /// poster_to_contributor | contributor_to_poster (check).
  direction  String
  /// 1–5.
  rating     Int
  feedback   String?
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  mission    MarketosMission @relation(fields: [missionId], references: [id])
  reviewee   MarketosMember  @relation("ReviewReviewee", fields: [revieweeId], references: [id])
  reviewer   MarketosMember  @relation("ReviewReviewer", fields: [reviewerId], references: [id])

  @@unique([missionId, direction])
  @@index([revieweeId, createdAt(sort: Desc)], map: "marketos_reviews_reviewee_idx")
  @@map("marketos_reviews")
}

model MarketosNotification {
  id        String         @id @default(uuid()) @db.Uuid
  orgId     String         @map("org_id") @db.Uuid
  memberId  String         @map("member_id") @db.Uuid
  /// One of the strings in the spec §3.10 enum-by-text list.
  type      String
  title     String
  body      String
  link      String?
  payload   Json?
  readAt    DateTime?      @map("read_at") @db.Timestamptz(6)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  member    MarketosMember @relation(fields: [memberId], references: [id])
  org       MarketosOrg    @relation(fields: [orgId], references: [id])

  @@index([memberId, readAt, createdAt(sort: Desc)], map: "marketos_notifications_inbox_idx")
  @@map("marketos_notifications")
}

model CapitalAccount {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String               @map("user_id") @db.Uuid
  name        String
  /// Stored in satangs (1/100 THB).
  balance     BigInt               @default(0)
  type        CapitalAssetType
  source      CapitalAccountSource @default(MANUAL)
  externalId  String?              @map("external_id")
  icon        String?
  color       String?
  archivedAt  DateTime?            @map("archived_at") @db.Timestamptz(6)
  createdAt   DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  saCategory  String?              @map("sa_category")
  mappingRole CapitalMappingRole?  @map("mapping_role")
  user        User                 @relation(fields: [userId], references: [id])

  @@unique([userId, externalId])
  @@index([userId, archivedAt])
  @@map("capital_accounts")
}

model CapitalLiability {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String
  /// Stored in satangs (negative value).
  balance    BigInt    @default(0)
  apr        Decimal?  @db.Decimal(5, 2)
  icon       String?
  color      String?
  archivedAt DateTime? @map("archived_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId, archivedAt])
  @@map("capital_liabilities")
}

model CapitalGoal {
  id         String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  name       String
  /// Current amount in satangs.
  current    BigInt              @default(0)
  /// Target amount in satangs.
  target     BigInt
  deadline   DateTime?           @db.Date
  priority   CapitalGoalPriority
  vehicle    String?
  archivedAt DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt  DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User                @relation(fields: [userId], references: [id])

  @@index([userId, archivedAt])
  @@map("capital_goals")
}

model CapitalSnapshot {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  date         DateTime @db.Date
  netWorth     BigInt   @map("net_worth")
  liquid       BigInt
  invested     BigInt
  liabilities  BigInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  saTotal      BigInt?  @map("sa_total")
  saPortfolios Json?    @map("sa_portfolios")
  fxRateUsdThb Decimal? @map("fx_rate_usd_thb") @db.Decimal(10, 4)
  saAssets     Json?    @map("sa_assets")
  user         User     @relation(fields: [userId], references: [id])

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("capital_snapshots")
}

model CapitalSettings {
  userId            String    @id @map("user_id") @db.Uuid
  runwayBurnRate    BigInt    @default(2500000) @map("runway_burn_rate")
  runwayAccountIds  String[]  @default([]) @map("runway_account_ids")
  /// ISO 4217 currency code for display (e.g., THB, USD, EUR)
  preferredCurrency String    @default("THB") @map("preferred_currency")
  /// BCP 47 locale for number formatting (e.g., en-US, th-TH)
  numberFormat      String    @default("en-US") @map("number_format")
  /// Date format string (YYYY-MM-DD, DD/MM/YYYY, MM/DD/YYYY)
  dateFormat        String    @default("YYYY-MM-DD") @map("date_format")
  /// UI theme: dark (default) or light
  theme             String    @default("dark")
  /// Last FX rate fetch timestamp for cache invalidation
  fxRatesUpdatedAt  DateTime? @map("fx_rates_updated_at") @db.Timestamptz(6)
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id])

  @@index([fxRatesUpdatedAt], map: "capital_settings_fx_cache_idx")
  @@map("capital_settings")
}

model CapitalSACategory {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String               @map("user_id") @db.Uuid
  portfolio_type CapitalPortfolioType
  name           String
  target_pct     Decimal?             @db.Decimal(5, 2)
  sortOrder      Int                  @default(0) @map("sort_order")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  assets         CapitalSAAsset[]
  user           User                 @relation("UserSACategories", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId, portfolio_type], map: "capital_sa_categories_user_portfolio_idx")
  @@map("capital_sa_categories")
}

model CapitalSAAsset {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId String            @map("category_id") @db.Uuid
  ticker     String
  name       String
  valueThb   BigInt?           @map("value_thb")
  shares     Decimal?          @db.Decimal(18, 6)
  targetPct  Decimal?          @map("target_pct") @db.Decimal(5, 2)
  sortOrder  Int               @default(0) @map("sort_order")
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  category   CapitalSACategory @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([categoryId], map: "capital_sa_assets_category_idx")
  @@map("capital_sa_assets")
}

model CapitalMappingConfig {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String             @map("user_id") @db.Uuid
  ynabAccId     String             @map("ynab_acc_id")
  /// @deprecated Legacy single category mapping. Use saAssetMappings instead. Will be removed in future version.
  saCategory    String?            @map("sa_category")
  /// JSONB array of SA asset mappings: [{saTicker: string}, ...]. Supports many-to-one SA asset → YNAB account mapping.
  saAssetMappings Json?            @map("sa_asset_mappings")
  role          CapitalMappingRole
  note          String?
  createdAt     DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User               @relation("UserMappingConfigs", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([userId, ynabAccId])
  @@index([userId], map: "capital_mapping_configs_user_idx")
  @@map("capital_mapping_configs")
}

model CapitalSyncLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  source     String
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  timestamp  DateTime @default(now()) @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, timestamp(sort: Desc)])
  @@map("capital_sync_logs")
