# Google Analytics 4 Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Tag Manager ID
NEXT_PUBLIC_GTM_MEASUREMENT_ID=GTM-XXXXXXX

# Site URL for OG meta and canonical links
NEXT_PUBLIC_SITE_URL=https://thanachon.me

# ChatBase widget embed script ID
NEXT_PUBLIC_CHATBASE_EMBED_ID=your-chatbase-embed-id

# GitHub Personal Access Token for fetching contribution stats
# Required scopes: read:user, public_repo
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxx

# Optional: Resend API key (only if using Netlify Function for custom email formatting)
# RESEND_API_KEY=re_xxxxx

# ---- PRAXIS (Phase 1) ----

# Supabase — publishable keys are safe in the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx

# Supabase service-role key (server-only; used by invite admin mint + middleware)
# SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# Short-lived invite JWT signing secret (generated via `openssl rand -base64 32`)
# PRAXIS_INVITE_SECRET=replace-me

# OpenRouter (LLM gateway) — required by `npm run praxis:eval` and all generation endpoints
# Sign up at https://openrouter.ai, then create a key under "Keys".
OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Optional: override the model used by the Week-0 eval harness.
# Verify the exact slug at https://openrouter.ai/models before running.
# PRAXIS_EVAL_MODEL=anthropic/claude-sonnet-4
# PRAXIS_EVAL_JUDGE_MODEL=anthropic/claude-sonnet-4

# Optional monthly spend ceiling (cents). Enforced by `src/lib/praxis/openrouter/ledger.ts` (Week 7).
# PRAXIS_MONTHLY_BUDGET_CENTS=5000